{
  "version": "2.0",
  "project": "PinchPad",
  "locks": {
    "network": {
      "dev_ui_port": 8282,
      "dev_api_port": 8383,
      "prod_unified_port": 8282,
      "architecture_note": "Dev: two processes (Vite HMR on 8282 + Express API on 8383). Prod: single Express process on 8282 (serves both /api/* and static dist/ files)"
    },
    "crypto": {
      "char_set_size": 62,
      "key_length": 64,
      "unbiased_generation": true,
      "rejection_sampling_limit": 248,
      "hash_algorithm": "SHA-256"
    },
    "auth": {
      "one_field_login": true,
      "session_storage_only": false,
      "session_duration": "24h",
      "namespaced_keys": "cc_*",
      "required_middleware": [
        "requireAuth",
        "requireHuman",
        "requirePermission",
        "lobsterRateLimiter"
      ],
      "audit_logging": "All auth events logged to audit_logs table (AUTH_REGISTER, AUTH_LOGIN_SUCCESS/FAILURE, AUTH_LOGOUT, AUTH_TOKEN_EXPIRED, PERMISSION_DENIED) with actor, ip_address, user_agent, timestamp"
    },
    "database": {
      "engine": "better-sqlite3",
      "journal_mode": "WAL",
      "foreign_keys": "ON",
      "constraints": {
        "key_hash": "UNIQUE",
        "user_uuid": "REQUIRED"
      }
    },
    "runtime": {
      "node_version_target": "22",
      "tsx_watch_no_ignore": true
    },
    "ui": {
      "sync_theme_initialization": true,
      "visual_hierarchy_lock": true,
      "brand_color_primary": "#f59e0b",
      "brand_pivot_locked": true,
      "allowed_exceptions": ["Localized contextual buttons (e.g. Cyan 'Create Account')"]
    }
  },
  "status": "STABLE_LOCKED",
  "last_lock_update": "2026-03-16T15:35:00Z",
  "maintained_by": "CrustAgent©™"
}