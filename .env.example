# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_API_URL: Frontend API endpoint (Vite define injection at build time)
# Leave UNSET for relative URLs (recommended for production — uses same host:port)
# Set to http://localhost:8282 for local dev (npm run dev uses Vite proxy)
# VITE_API_URL=

# DB_ENCRYPTION_KEY: SQLite Database Encryption Key (AES-256 via SQLCipher)
# Generate with: openssl rand -base64 48
# Leave unset for unencrypted DB (not recommended for production)
# DB_ENCRYPTION_KEY=

# ADMIN_TOKEN: Optional. Set to enable the /admin SuperAdmin panel.
# Generate with: openssl rand -base64 48
# If unset, admin panel is completely disabled (no routes mounted).
# ADMIN_TOKEN=

# AUDIT_RETENTION_DAYS: Days to keep audit logs (30, 60, or 90 recommended)
# AUDIT_RETENTION_DAYS=90

# ENABLE_SHELL_PROXY: Optional. Enable public read-only pearl sharing.
# ENABLE_SHELL_PROXY=false

# SHELL_PROXY_RATE_LIMIT: Optional. Request limit for public shares.
# SHELL_PROXY_RATE_LIMIT=60


