{
  "name": "pinchpad",
  "private": true,
  "version": "1.0.0",
  "description": "Secure Agent Management and Note-taking platform with ClawKeys©™ and ShellCryption©™.",
  "type": "module",
  "scripts": {
    "scuttle": "npm run scuttle:dev-start",
    "scuttle:prod": "npm run scuttle:prod-start",
    "scuttle:dev-start": "npm run dev:server & npm run dev",
    "scuttle:dev-stop": "fuser -k 8282/tcp 8383/tcp || true",
    "scuttle:prod-start": "npm run build && (NODE_ENV=production PORT=8383 tsx server.ts & vite preview --port 8282 --host)",
    "scuttle:prod-stop": "npm run scuttle:dev-stop",
    "scuttle:reset": "npm run scuttle:stop && rm -rf dist && rm -rf data && mkdir -p data",
    "scuttle:reset-db": "rm -f data/clawstack.db && echo '✅ Database reset. Restart server to recreate schema.'",
    "scuttle:stop": "npm run scuttle:dev-stop",
    "clean": "rm -rf dist",
    "dev": "vite --port 8282 --strictPort",
    "dev:server": "PORT=8383 tsx --watch server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3-multiple-ciphers": "^9.1.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dompurify": "^3.4.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jszip": "^3.10.1",
    "katex": "^0.16.45",
    "lucide-react": "^0.546.0",
    "marked": "^18.0.2",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/marked": "^5.0.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.21",
    "jsdom": "^24.1.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.0"
  }
}
