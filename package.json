{
  "name": "pinchpad",
  "private": true,
  "version": "1.0.0",
  "description": "Secure Agent Management and Note-taking platform with ClawKeys©™ and ShellCryption©™.",
  "type": "module",
  "scripts": {
    "scuttle:dev-start": "npm run dev:server & npm run dev &",
    "scuttle:dev-stop": "fuser -k 8282/tcp 8383/tcp || true",
    "scuttle:prod-start": "npm run build && NODE_ENV=production tsx server.ts &",
    "scuttle:prod-stop": "fuser -k 8282/tcp 8383/tcp || true",
    "scuttle:reset": "npm run scuttle:prod-stop && rm -rf dist",
    "scuttle:reset-dev": "npm run scuttle:dev-stop && rm -rf dist",
    "clean": "rm -rf dist",
    "dev": "vite",
    "dev:server": "tsx --watch --ignore data/** server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3-multiple-ciphers": "^9.1.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.21",
    "jsdom": "^24.1.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.0"
  }
}
